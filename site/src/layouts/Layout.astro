---
// The shell every page shares: a sidebar, and the page beside it.
//
// The sidebar is the site's table of contents, and it is built from the *data* rather
// than hand-written: every workload declared on disk, every campaign measured on it,
// the head-to-head, and the methodology. A campaign is `(workload, machine)`, so that
// is the shape the nav has — a campaign sits *under* the work it measured, never
// beside it, because a millisecond means nothing until you know what was computed.
//
// `ClientRouter` is what makes a heap of prerendered pages behave like one app. It
// swaps the document client-side instead of reloading it, so the JavaScript realm
// survives a navigation — and with it the module singleton in `campaigns.ts` that
// holds the WebAssembly instance and the parsed campaigns. The reader gets a real URL
// for every view *and* pays for the 500 kB campaign once.

import { ClientRouter } from "astro:transitions";
import { sections } from "../nav";
import "../theme.css";

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

const base = import.meta.env.BASE_URL;

// Astro serves `/compare` and `/compare/` as the same page; the nav highlights on the
// normalized path so neither spelling lights up the wrong entry.
const path = `${Astro.url.pathname.replace(/\/$/, "")}/`;
const nav = sections(base);
const current = (href: string) => path === href.replace(/\/$/, "") + "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body>
    <div class="shell">
      {/* On a phone the sidebar is a `<details>` that starts closed: a nav listing every
          campaign of every workload would otherwise push the numbers a screen and a half
          down. On a wide viewport the CSS forces it open and the marker disappears. */}
      <details class="sidebar" open>
        <summary class="sidebar-head">
          <a class="brand" href={base}>langbench</a>
          <span class="sidebar-toggle" aria-hidden="true">menu</span>
        </summary>

        <nav class="sidebar-nav" aria-label="Site">
          {
            nav.map((section) => (
              <div class="nav-section">
                <p class="nav-title">{section.title}</p>
                <ul>
                  {section.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class={current(link.href) ? "current" : ""}
                        aria-current={current(link.href) ? "page" : undefined}
                      >
                        {link.label}
                      </a>
                      {link.children !== undefined && link.children.length > 0 && (
                        <ul class="nav-children">
                          {link.children.map((child) => (
                            <li>
                              <a
                                href={child.href}
                                class={current(child.href) ? "current" : ""}
                                aria-current={current(child.href) ? "page" : undefined}
                              >
                                {child.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>

        {/* The source, at the bottom of the nav and set apart from it: everything above
            is a page of this site, and this one leaves it. The arrow-out-of-a-box is what
            says so — `target="_blank"` without a visible marker is a link that behaves in
            a way it never announced. `rel="noreferrer"` because the new tab has no
            business holding a handle on this one.

            Both icons are inline SVG: the site ships no external asset, and a logo that
            arrives over the network is a logo that can fail to arrive. */}
        <a
          class="sidebar-source"
          href="https://github.com/leroyguillaume/langbench"
          target="_blank"
          rel="noreferrer"
        >
          <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            ></path>
          </svg>
          <span>Source on GitHub</span>
          <svg
            class="external"
            viewBox="0 0 16 16"
            width="12"
            height="12"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.5 3h-3A1.5 1.5 0 0 0 2 4.5v8A1.5 1.5 0 0 0 3.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-3M9.5 2.5h4v4M13 3 7.5 8.5"
            ></path>
          </svg>
        </a>
      </details>

      <div class="content">
        <slot />

        <footer class="site-footer">
          <p>
            Compiler and runtime backends, measured. Every number on this site is the harness's
            own — min-of-N, the buckets, the definition of startup all live in <code
              >src/analysis.rs</code
            >, compiled to WebAssembly and called from this page. The site sorts, formats and
            draws; it never does arithmetic on a sample.
          </p>
          <p>
            <a href="https://github.com/leroyguillaume/langbench">Source</a> ·
            <a href={`${base}methodology/`}>Read the methodology before trusting a number</a>
          </p>
        </footer>
      </div>
    </div>
  </body>
</html>
