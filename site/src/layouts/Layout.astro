---
// The shell every page shares: the masthead, the nav, and nothing else.
//
// `ClientRouter` is what makes three prerendered pages behave like one app. It
// swaps the document client-side instead of reloading it, so the JavaScript realm
// survives a navigation — and with it the module singleton in `campaigns.ts` that
// holds the WebAssembly instance and the parsed campaigns. The reader gets a real
// URL for every view *and* pays for the 500 kB campaign once.

import { ClientRouter } from "astro:transitions";
import "../theme.css";

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

const base = import.meta.env.BASE_URL;
const links = [
	{ href: base, label: "Results" },
	{ href: `${base}compare/`, label: "Compare" },
	{ href: `${base}methodology/`, label: "Methodology" },
];

// Astro serves `/compare` and `/compare/` as the same page; the nav highlights on
// the normalized path so neither spelling lights up the wrong tab.
const path = `${Astro.url.pathname.replace(/\/$/, "")}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>langbench</a>
      <nav class="site-nav">
        {
          links.map((link) => (
            <a
              href={link.href}
              class={path === link.href.replace(/\/$/, "") + "/" ? "current" : ""}
              aria-current={path === link.href.replace(/\/$/, "") + "/" ? "page" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <p>
        Compiler and runtime backends, measured. Every number on this site is the harness's own —
        min-of-N, the buckets, the definition of startup all live in <code>src/analysis.rs</code>,
        compiled to WebAssembly and called from this page. The site sorts, formats and draws; it
        never does arithmetic on a sample.
      </p>
      <p>
        <a href="https://github.com/leroyguillaume/langbench">Source</a> ·
        <a href={`${base}methodology/`}>Read the methodology before trusting a number</a>
      </p>
    </footer>
  </body>
</html>
