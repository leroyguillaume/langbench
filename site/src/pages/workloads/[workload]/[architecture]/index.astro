---
// A campaign: one machine, one workload, and what it measured.
//
// The route *is* the campaign — `/workloads/mandelbrot/x86_64/` — because a campaign
// is `(workload, machine)` and both halves have to be in the address for a link to
// name one. There is no selector at the top of this page any more: picking a campaign
// is navigating, and the sidebar is where you do it. Two architectures are never on
// one screen, which is the architecture rule enforced by the shape of the site rather
// than by a note under a chart.
//
// The island reads the campaign whose *header* says it is this one — never the file
// whose name looks right. The path is a URL; the header is what the run recorded.
//
// The column reference is slotted in rather than placed after: it belongs under the
// table it explains. It is a methodology page, rendered at build time, and the browser
// gets no Markdown renderer for it.
//
// What the backends *are* is not here. That comes from their manifests, it does not
// change with the machine that ran them, and it is on the workload's page — each row of
// the table links straight to it.

import { Results } from "../../../../components/Results";
import Layout from "../../../../layouts/Layout.astro";
import { campaigns } from "../../../../site";

export function getStaticPaths() {
	return campaigns.map((campaign) => ({
		params: { workload: campaign.workload, architecture: campaign.architecture },
		props: { campaign },
	}));
}

const { campaign } = Astro.props;
---

<Layout
  title={`${campaign.workload} on ${campaign.architecture} — langbench`}
  description={`Every backend of the ${campaign.workload} workload, measured on ${campaign.architecture}. Raw samples, aggregated in your browser by the harness itself.`}
>
  <Results client:only="react" workload={campaign.workload} architecture={campaign.architecture} />
</Layout>
